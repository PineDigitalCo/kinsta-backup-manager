{
	"name": "pinedigitalco/kinsta-backup-manager",
	"description": "Manage Kinsta site backups from WordPress via the Kinsta API.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"szepeviktor/phpstan-wordpress": "^2.0"
	},
	"config": {
		"sort-packages": true
	},
	"scripts": {
		"analyse": "phpstan analyse --memory-limit=1G",
		"phpstan": "phpstan analyse --memory-limit=1G"
	}
}
